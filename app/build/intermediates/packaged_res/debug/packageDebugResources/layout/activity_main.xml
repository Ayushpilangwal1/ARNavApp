<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <android.opengl.GLSurfaceView
        android:id="@+id/surfaceView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B3121212">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AR Indoor Navigator"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Assistive Navigation for Visually Impaired"
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginBottom="24dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1E1E1E"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STATUS"
                    android:textSize="10sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Starting up..."
                    android:textSize="15sp"
                    android:textColor="#FFFFFF"
                    android:minHeight="40dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1E1E1E"
                android:padding="16dp"
                android:layout_marginBottom="28dp">

                <TextView
                    android:id="@+id/tvPosition"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Position: initializing..."
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:textColor="#90CAF9"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvWaypointCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Waypoints saved: 0"
                    android:textSize="13sp"
                    android:textColor="#A5D6A7"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnStartRecording"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="14dp"
                android:text="Start Recording"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4CAF50"
                android:enabled="false" />

            <Button
                android:id="@+id/btnSaveWaypoint"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="14dp"
                android:text="Save Waypoint"
                android:textSize="16sp"
                android:textColor="#000000"
                android:backgroundTint="#FFC107"
                android:enabled="false" />

            <Button
                android:id="@+id/btnStartNavigation"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="24dp"
                android:text="Start Navigation"
                android:textSize="16sp"
                android:textColor="#000000"
                android:backgroundTint="#2196F3"
                android:enabled="false" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. Tap Start Recording and walk.\n2. Tap Save Waypoint ONLY at important landmarks (like a door).\n3. Tap Stop Recording when done.\n4. Tap Start Navigation to be guided back."
                android:textSize="12sp"
                android:textColor="#555555"
                android:lineSpacingMultiplier="1.5"/>

        </LinearLayout>
    </ScrollView>
</FrameLayout>